# SentinelGrid — Frontend environment variables
# Copy this file to `.env` and fill in the real values.

# Base URL of the backend. Do NOT include a trailing slash.
# Local dev example:    http://localhost:8001
# Emergent preview:     https://<your-app>.preview.emergentagent.com
REACT_APP_BACKEND_URL=http://localhost:8001

# Disable CRA hot reload polling in local dev if the container has no inotify
WDS_SOCKET_PORT=443
