# SentinelGrid — Backend environment variables
# Copy this file to `.env` and fill in the real values.

# MongoDB connection string (local: mongodb://localhost:27017)
MONGO_URL="mongodb://localhost:27017"

# Mongo database name
DB_NAME="sentinelgrid"

# CORS origins, comma-separated. Use "*" for local dev.
CORS_ORIGINS="*"

# Emergent Universal LLM key (works with Gemini/OpenAI/Claude via emergentintegrations).
# Get one from your Emergent profile → Universal Key.
EMERGENT_LLM_KEY="sk-emergent-XXXXXXXXXXXXXXXX"

# JWT signing secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET="replace-with-a-64-char-hex-secret"
